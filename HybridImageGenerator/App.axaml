<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:HybridImageGenerator"
             xmlns:dialogHostAvalonia="clr-namespace:DialogHostAvalonia;assembly=DialogHost.Avalonia"
             xmlns:views="clr-namespace:HybridImageGenerator.Views"
             xmlns:errorHandling="clr-namespace:HybridImageGenerator.ViewModels.ErrorHandling"
             xmlns:viewModels="clr-namespace:HybridImageGenerator.ViewModels"
             x:Class="HybridImageGenerator.App"
             RequestedThemeVariant="Default">
    
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type errorHandling:DesktopErrorViewModel}"><views:ErrorView /></DataTemplate>
        <DataTemplate DataType="{x:Type errorHandling:WebErrorViewModel}"><views:ErrorView /></DataTemplate>
        <DataTemplate DataType="{x:Type viewModels:RescaleWarningViewModel}"><views:RescaleWarningView /></DataTemplate>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <dialogHostAvalonia:DialogHostStyles />
    </Application.Styles>
             
    <Application.Resources>
        <!-- Sliders -->
        <SolidColorBrush x:Key="SliderThumbBackground" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPressed" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderTrackValueFill" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderTrackValueFillPointerOver" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderTrackValueFillPressed" Color="#6366F1"/>
        <SolidColorBrush x:Key="SliderTrackFill" Color="#2D3748"/>
        
        <SolidColorBrush x:Key="ButtonBackground" Color="#6366F1 "/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2D3748"/>
        
        
        
    </Application.Resources>
</Application>