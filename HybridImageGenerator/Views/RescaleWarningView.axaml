<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HybridImageGenerator.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HybridImageGenerator.Views.RescaleWarningView"
             x:DataType="viewModels:RescaleWarningViewModel">
    
    <Grid ColumnDefinitions="*, *" RowDefinitions="*, *, *">
        <TextBox Grid.ColumnSpan="2" TextWrapping="Wrap" Text="{Binding WarningMessage}"></TextBox>
        <CheckBox Grid.Column="0" Grid.Row="1" IsChecked="{Binding DontShowForThisSize}">Don't show again for current size</CheckBox>
        <Button Grid.Row="2" Grid.Column="0" Command="{Binding OkCommand}">Ok</Button>
        <Button Grid.Row="2" Grid.Column="1" Command="{Binding CancelCommand}">Cancel</Button>
    </Grid>
</UserControl>
