<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HybridImageGenerator.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HybridImageGenerator.Views.SafeZoneToolTipView"
             x:DataType="viewModels:SafeZoneToolTipViewModel"
             Background="#000000">
    
    <StackPanel Margin="10" Spacing="5" Orientation="Vertical">
        <TextBlock Text="Safe zone tool tip placeholder text"/>
        <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CloseCommand}" Content="Got it"/>
    </StackPanel>
</UserControl>
