<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:HybridImageGenerator.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="HybridImageGenerator.Views.SafeZoneToolTipView"
             x:DataType="viewModels:SafeZoneToolTipViewModel">
    <StackPanel Orientation="Vertical">
        <TextBlock>Safe zone tool tip placeholder text</TextBlock>
        <Button Command="{Binding CloseCommand}">Got it</Button>
    </StackPanel>
</UserControl>
